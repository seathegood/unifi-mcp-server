# Copy this file to deploy/env and replace placeholders.
# Do not commit deploy/env with real secrets.

# Common names in other stacks (not read directly by this app):
# UNIFI_BASE_URL=https://api.ui.com
# UNIFI_API_TOKEN=your-token

# Required by this project
UNIFI_API_KEY=changeme
UNIFI_API_TYPE=cloud-v1
UNIFI_CLOUD_API_URL=https://api.ui.com

# Local-only mode (set when UNIFI_API_TYPE=local)
# UNIFI_LOCAL_HOST=192.168.1.1
UNIFI_LOCAL_PORT=443
UNIFI_LOCAL_VERIFY_SSL=true

# Optional site selector
UNIFI_DEFAULT_SITE=default
# Legacy alias accepted by the app:
# UNIFI_SITE=default
UNIFI_SITE_MANAGER_ENABLED=false

# MCP HTTP server (Traefik routes to this internal listener)
MCP_PROFILE=deep-research
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_PATH=/mcp

# Logging / audit
LOG_LEVEL=INFO
LOG_API_REQUESTS=true
UNIFI_AUDIT_LOG_ENABLED=true

# Reliability / cache
UNIFI_RATE_LIMIT_REQUESTS=100
UNIFI_RATE_LIMIT_PERIOD=60
UNIFI_MAX_RETRIES=3
UNIFI_RETRY_BACKOFF_FACTOR=2.0
UNIFI_REQUEST_TIMEOUT=30
UNIFI_CACHE_ENABLED=true
UNIFI_CACHE_TTL=300

# Document redaction flags (recommended false in shared environments)
INCLUDE_MACS=false
INCLUDE_SERIALS=false
INCLUDE_PUBLIC_IP=false
