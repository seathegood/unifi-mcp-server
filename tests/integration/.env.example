# UniFi Test Environment Configuration
# Copy this file to .env and fill in your credentials

# UniFi Lab Environment (Local API)
UNIFI_LAB_API_KEY=your-lab-api-key-here
UNIFI_LAB_HOST=10.2.0.1
UNIFI_LAB_PORT=443
UNIFI_LAB_VERIFY_SSL=false

# UniFi Home Environment (Local API)
UNIFI_HOME_API_KEY=your-home-api-key-here
UNIFI_HOME_HOST=192.168.1.1
UNIFI_HOME_PORT=443
UNIFI_HOME_VERIFY_SSL=false

# UniFi Cloud Environment
UNIFI_CLOUD_API_KEY=your-cloud-api-key-here
UNIFI_CLOUD_API_TYPE=cloud-v1  # or cloud-ea

# Test Configuration
TEST_VERBOSE=false
TEST_EXPORT_RESULTS=true
TEST_RESULTS_DIR=./test_results
