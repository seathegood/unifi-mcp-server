# UniFi MCP Server - Example Environment (placeholders only)
# Copy to .env locally and fill real secrets outside of version control.

UNIFI_API_KEY=changeme
UNIFI_API_TYPE=cloud-v1
UNIFI_CLOUD_API_URL=https://api.ui.com
# UNIFI_LOCAL_HOST=192.168.128.1
UNIFI_LOCAL_PORT=443
UNIFI_LOCAL_VERIFY_SSL=true

UNIFI_DEFAULT_SITE=default
UNIFI_SITE_MANAGER_ENABLED=false

MCP_SERVER_PORT=3000
MCP_LOG_LEVEL=INFO
LOG_LEVEL=INFO
LOG_API_REQUESTS=true
UNIFI_AUDIT_LOG_ENABLED=true

UNIFI_RATE_LIMIT_REQUESTS=100
UNIFI_RATE_LIMIT_PERIOD=60
UNIFI_MAX_RETRIES=3
UNIFI_RETRY_BACKOFF_FACTOR=2.0
UNIFI_REQUEST_TIMEOUT=30
UNIFI_CACHE_ENABLED=true
UNIFI_CACHE_TTL=300

AGNOST_ENABLED=false
AGNOST_ORG_ID=
AGNOST_ENDPOINT=https://api.agnost.ai
AGNOST_DISABLE_INPUT=false
AGNOST_DISABLE_OUTPUT=false

TOOLBOX_VERSION=0.26.0
TOOLBOX_PORT=8080
TOOLBOX_SERVICE_NAME=unifi-mcp-toolbox

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

WEBHOOK_SECRET=
