# UniFi Account Credentials
# Create a .env file with your actual credentials (never commit .env to git)

# UniFi account email
UNIFI_EMAIL=your.email@example.com

# UniFi account password
UNIFI_PASSWORD=your_password_here

# Optional: Headless mode (true/false)
HEADLESS=true

# Optional: Screenshot directory for debugging
SCREENSHOT_DIR=./screenshots

# Optional: Authentication timeouts (in milliseconds)
AUTH_PASSKEY_TIMEOUT=120000  # 120 seconds for passkey/WebAuthn
AUTH_2FA_TIMEOUT=90000       # 90 seconds for 2FA code entry
AUTH_PASSWORD_TIMEOUT=10000  # 10 seconds to find password field
